flowchart TD
                    A[需求收集] --> B[宪法对照审查]
                    B --> C{审查通过?}
                    C -->|是| D[规约制定]
                    C -->|否| E[需求调整]
                    E --> B
                    D --> F[验证设计]
                    F --> G[实现审查]
                    G --> H[交付验收]
                    
                    style A fill:#667eea,stroke:#667eea,stroke-width:2px,color:#fff
                    style B fill:#4ecdc4,stroke:#4ecdc4,stroke-width:2px,color:#fff
                    style C fill:#ff6b6b,stroke:#ff6b6b,stroke-width:2px,color:#fff
                    style D fill:#667eea,stroke:#667eea,stroke-width:2px,color:#fff
                    style E fill:#ffe66d,stroke:#ffe66d,stroke-width:2px,color:#333
                    style F fill:#4ecdc4,stroke:#4ecdc4,stroke-width:2px,color:#fff
                    style G fill:#4ecdc4,stroke:#4ecdc4,stroke-width:2px,color:#fff
                    style H fill:#95e1d3,stroke:#95e1d3,stroke-width:2px,color:#333