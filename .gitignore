# ============================================
# Spinor-Taiji Model - 文件管理规范
# ============================================
# 
# 发布内容范围：
#   ✅ docs/          - 核心文档库（必须上传）
#   ✅ articles/      - 公众号文章（必须上传）
#   ✅ README.md      - 项目说明（必须上传）
#   ✅ LICENSE        - 许可证（必须上传）
#   ✅ CONTRIBUTING.md - 贡献指南（必须上传）
#   
# 本地工作文件（不上传）：
#   ❌ scripts/       - 工具脚本
#   ❌ media/         - 媒体资源
#   ❌ data/          - 数据文件
#   ❌ skill/         - 技能文档
#   ❌ templates/     - 模板文件
#   ❌ .github/       - GitHub配置
# ============================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
ENV/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Project specific - 本地工作文件
*.log
.env
.env.local
secrets/
credentials/

# Local working directories (NOT for publishing)
# scripts/ - 已移除排除，允许上传构建脚本
media/
data/
skill/
templates/
.github/

# Temporary files
*.tmp
*.bak
*.backup

# Nested directory (accidental creation)
spinor-taiji-model/
